{
  "name": "research-lab",
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal filesystem-first research runner with lane execution, evidence artifacts, logs, and validation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sommbc/research-lab.git"
  },
  "bugs": {
    "url": "https://github.com/sommbc/research-lab/issues"
  },
  "homepage": "https://github.com/sommbc/research-lab#readme",
  "keywords": [
    "research",
    "orchestration",
    "source-grounded",
    "runtime"
  ],
  "bin": {
    "research-lab": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "research-lab": "tsx src/cli.ts",
    "example:run": "tsx src/cli.ts run examples/apollo-13-oxygen-tank-review --force --max-concurrency 2 && tsx src/cli.ts synthesize examples/apollo-13-oxygen-tank-review --force && tsx src/cli.ts validate examples/apollo-13-oxygen-tank-review && tsx scripts/examples/render-status-screenshot.ts examples/apollo-13-oxygen-tank-review",
    "example:screenshot": "tsx scripts/examples/render-status-screenshot.ts examples/apollo-13-oxygen-tank-review",
    "example:status": "tsx src/cli.ts status examples/apollo-13-oxygen-tank-review",
    "composio:list-toolkits": "tsx scripts/composio/list-toolkits.ts",
    "composio:inspect-toolkit": "tsx scripts/composio/inspect-toolkit.ts",
    "composio:create-research-sessions": "tsx scripts/composio/create-research-sessions.ts",
    "composio:print-codex-mcp-config": "tsx scripts/composio/print-codex-mcp-config.ts",
    "preflight:first-run": "tsx scripts/preflight/first-run-readiness.ts",
    "preflight:context": "tsx scripts/preflight/context-preflight.ts",
    "preflight:tool-policy": "tsx scripts/preflight/tool-policy-check.ts",
    "preflight:artifact-standard": "tsx scripts/preflight/artifact-standard-check.ts",
    "preflight": "npm run preflight:first-run && npm run preflight:context && npm run preflight:tool-policy && npm run preflight:artifact-standard",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@composio/core": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
